# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Set default editor
export EDITOR=emacs

# Set AWS profile
export AWS_PROFILE=David-SSO

# Ignore case for tab-completion (applied by Oh My Zsh's compinit below)
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Oh My Zsh + Powerlevel10k
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
    docker
    docker-compose
    npm
    node
    python
    ruby
)
source "$ZSH/oh-my-zsh.sh"

# Zsh history settings
setopt APPEND_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY

# Set word boundaries to bash style
autoload -U select-word-style
select-word-style bash

# Aliases (modern coreutils replacements available on Linux)
alias ls='exa'
alias ll='exa -la'
alias la='exa -la'
alias cat='bat'
alias grep='rg'
alias find='fd'

# Enable fzf (if installed)
if command -v fzf > /dev/null 2>&1; then
  [ -f /usr/share/doc/fzf/examples/completion.zsh ] && source /usr/share/doc/fzf/examples/completion.zsh
  [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
fi

# Install ngrok completions
if command -v ngrok > /dev/null 2>&1; then
  eval "$(ngrok completion)"
fi

# Add custom bin directories to PATH
export PATH="$PATH:$HOME/bin:$HOME/Code/bin"

# Initialize asdf (single version manager for node, python, java, ruby, etc.)
. "$HOME/.asdf/asdf.sh"
. "$HOME/.asdf/completions/asdf.bash"
# Native Claude Code install — keep ~/.local/bin ahead of asdf shims so an
# asdf-shimmed (npm) claude can never intercept the node-independent native binary.
export PATH="$HOME/.local/bin:$PATH"

# For Colemak-DH keyboard layout left home row keys ``arst` == `asdf`
alias arst='asdf'

# Set JAVA_HOME (only if asdf manages a java version)
if asdf where java > /dev/null 2>&1; then
  export JAVA_HOME="$(asdf where java)"
fi

# Load Powerlevel10k configuration
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
